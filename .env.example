# --- API CONFIGURATION ---
GEMINI_API_KEY=AIzaSy...
AI_MODEL=gemini-1.5-flash
AI_TEMPERATURE=1

# --- DIRECTORY CONFIGURATION ---
ROOT_PATH=auto-grader-laprak
CURRENT_MEETING=pertemuan_4
SUBMISSION_SUBFOLDER=submissions
EXTRACTED_SUBFOLDER=extracted
RESULTS_SUBFOLDER=results
LOGS_SUBFOLDER=logs

# --- ASSIGNMENT RULES (CUSTOMIZABLE) ---
ASSIGNMENT_TITLE="Implementasi Rekursif pada C++"
# Kosongkan jika tidak ada rule khusus
SPECIAL_RULE="WAJIB menggunakan skema rekursif. Jika menggunakan looping (for/while) untuk logika utama, berikan penalti skor dan catat di kolom Aturan_Khusus."

# --- TECHNICAL SETTINGS ---
ALLOWED_EXTENSIONS=.c,.cpp,.py,.java
STUDENT_ID_REGEX=^\d{14}_\d+\s-\s[a-zA-Z][a-zA-Z\s'.-]*$

# --- RATE LIMIT CONTROL ---
# Delay antar request ke AI (dalam detik)
API_DELAY_SECONDS=2